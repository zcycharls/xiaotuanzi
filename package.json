{
  "name": "xiaotuanzi",
  "version": "1.0.0",
  "description": "小团子 ADHD 陪伴宠物",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "build": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.xiaotuanzi.app",
    "productName": "小团子",
    "directories": {
      "output": "dist"
    },
    "files": [
      "app/**/*",
      "main.js",
      "preload.js"
    ],
    "win": {
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "electronVersion": "28.3.3"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "@electron/packager": "^18.0.0",
    "electron-builder": "^24.0.0"
  }
}